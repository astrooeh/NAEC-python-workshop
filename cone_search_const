<INFO name="QUERY" value="
    SELECT TOP 10000 pmra,
        pmdec,
        bp_rp,
        phot_g_mean_mag,
        parallax,
        parallax_error
    FROM gaiadr3.gaia_source
    WHERE CONTAINS(
        POINT(&#039;ICRS&#039;, ra, dec),
        CIRCLE(&#039;ICRS&#039;, 245.89675000000003, -26.525750000000002, 0.5)
    ) = 1
    AND parallax &gt; 0.0
    AND SQRT(POWER(pmra - -12.48, 2) + POWER(pmdec - -18.99, 2)) &lt; 1.5
    AND parallax_error / parallax &lt; 0.15
    " ucd="meta.query"/>

